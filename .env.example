# Copy to .env and fill in. Next.js also reads .env.local for app secrets.
# For production (Vercel, etc.), set these in the dashboard as environment variables.

# PostgreSQL (required for chat, KPI stats, seed data).
# Local: postgresql://postgres:postgres@localhost:5432/dsfnb?schema=public
# Docker: docker run -d --name dsfnb-pg -e POSTGRES_USER=postgres -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=dsfnb -p 5432:5432 postgres:16-alpine
# Cloud: Neon, Supabase, or any PostgreSQL — paste the connection string.
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Required if you store LLM API keys in Settings (32 bytes = 64 hex chars). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# Chat LLM (optional). With key only, OpenAI API is used by default.
# DEFAULT_CHAT_LLM_KEY=your-openai-or-compatible-key
# DEFAULT_CHAT_LLM_URL=https://api.openai.com
